<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link
  rel="preload"
  as="font"
  type="font/woff2"
  href="assets/fonts/Gilroy-SemiBold.woff2"
  crossorigin
>
<link rel="stylesheet" href="/styles/main.css">

{% set pageTitle = title + ' - ' + site.name %}
{% set pageDesc = '' %}
{% set siteTitle = site.name %}
{% set currentUrl = site.url + page.url %}
{% if metaTitle %}
  {% set pageTitle = metaTitle %}
{% endif %}

{% if metaDesc %}
  {% set pageDesc = metaDesc %}
{% endif %}

<title>{{ pageTitle }}</title>
<link rel="canonical" href="{{ currentUrl }}">
<meta property="og:site_name" content="{{ siteTitle }}">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ currentUrl }}">
<meta name="twitter:creator" content="@{{ site.authorHandle }}">
<meta name="twitter:dnt" content="on">

{% if metaDesc %}
  <meta name="description" content="{{ metaDesc }}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  <meta property="og:description" content="{{ metaDesc }}">
{% endif %}

{% if socialImage %}
  <meta property="og:image" content="{{ socialImage }}">
  <meta name="twitter:image" content="{{ socialImage }}">
  <meta property="og:image:alt" content="Page image for {{ site.name }}">
  <meta name="twitter:image:alt" content="Page image for {{ site.name }}">
{% endif %}

<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<link rel="icon" type="image/png" href="{{ site.images.favicon }}">

<script>
  document
    .documentElement
    .classList
    .remove('no-js');
</script>
