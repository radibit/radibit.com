---
// Shared navigation: logo + blog link + theme toggle
---

<nav class="flex justify-between items-center py-7 px-10 border-b border-subtle desk:px-16">
  <a href="/" aria-label="radibit home" class="flex items-center no-underline">
    <svg
      viewBox="0 0 427 426"
      xmlns="http://www.w3.org/2000/svg"
      fill-rule="evenodd"
      clip-rule="evenodd"
      stroke-linejoin="round"
      stroke-miterlimit="2"
      width="48"
      height="48"
      aria-hidden="true"
    >
      <path
        d="M.964 122.489v-.563L123.705.364v122.125V.364h302.532v303.147h-.3L303.496 425.636H.964V122.489z"
        class="fill-fg"
      />
      <g font-family="'Futura-Medium','Futura',sans-serif" font-weight="500" font-size="110.64">
        <text x="71.6" y="250.816" class="fill-bg">
          r<tspan x="112.225px 178.566px" y="250.816px 250.816px">adi</tspan>
        </text>
        <text x="151.419" y="375.287" class="fill-accent">bit</text>
      </g>
    </svg>
  </a>

  <div class="flex items-center gap-5">
    <a
      href="/posts"
      class="font-sans text-[0.8125rem] font-semibold tracking-widest uppercase text-fg no-underline opacity-70 transition-opacity duration-200 hover:opacity-100"
    >
      Blog
    </a>

    <button
      id="theme-toggle"
      aria-label="Switch colour theme"
      class="flex items-center gap-2 bg-transparent border-[1.5px] border-fg text-fg px-4 py-[0.45rem] font-sans text-[0.8125rem] font-medium tracking-widest uppercase cursor-pointer transition-colors duration-200 hover:bg-fg hover:text-bg"
    >
      <span aria-hidden="true" class="text-[0.9rem] leading-none">◐</span>
      <span id="theme-label">System mode</span>
    </button>
  </div>
</nav>

<script>
  const MODES = ['system', 'light', 'dark'] as const;
  type Mode = (typeof MODES)[number];

  const toggle = document.getElementById('theme-toggle');
  const label = document.getElementById('theme-label');
  const html = document.documentElement;

  const modeLabels: Record<Mode, string> = {
    system: 'System mode',
    light: 'Light mode',
    dark: 'Dark mode',
  };

  function getStoredMode(): Mode {
    const saved = localStorage.getItem('theme');
    if (saved === 'light' || saved === 'dark') return saved;
    return 'system';
  }

  function applyMode(mode: Mode) {
    if (mode === 'system') {
      localStorage.removeItem('theme');
      const sys = window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light';
      html.setAttribute('data-theme', sys);
    } else {
      localStorage.setItem('theme', mode);
      html.setAttribute('data-theme', mode);
    }
    if (label) label.textContent = modeLabels[mode];
  }

  let currentMode: Mode = getStoredMode();
  // Set label on init; theme is already applied by the no-flash inline script
  if (label) label.textContent = modeLabels[currentMode];

  toggle?.addEventListener('click', () => {
    const idx = MODES.indexOf(currentMode);
    currentMode = MODES[(idx + 1) % MODES.length];
    applyMode(currentMode);
  });
</script>
