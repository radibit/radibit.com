---
import type { MarkdownLayoutProps } from 'astro';
import SiteNav from '../components/SiteNav.astro';
import Layout from './Layout.astro';

type Props = MarkdownLayoutProps<{
  title: string;
  external_url?: string;
}>;

const { frontmatter } = Astro.props;
const { title, external_url } = frontmatter;
---

<Layout title={`${title} · radibit`}>
  <SiteNav />

  <main class="pt-12 px-10 pb-20 desk:px-16">
    <article class="max-w-[72ch] mx-auto">

      {external_url ? (
        <div>
          <h1 class="font-display font-optical-auto text-[clamp(2rem,5vw,3rem)] font-semibold leading-[1.1] tracking-[-0.03em] mb-8">
            {title}
          </h1>

          <div class="border-[1.5px] border-fg px-9 py-8 mt-6">
            <p class="text-[0.75rem] font-semibold tracking-[0.14em] uppercase text-accent mb-4">
              External article
            </p>
            <p class="text-base leading-[1.65] opacity-[0.8] mb-6">
              This post was published externally. Click the link below to read the full article.
            </p>
            <a
              href={external_url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block text-[0.75rem] font-semibold tracking-widest uppercase text-bg bg-fg no-underline px-7 py-[0.85rem] transition-opacity duration-200 hover:opacity-75"
            >
              Read on external site <span aria-hidden="true">→</span>
              <span class="sr-only"> (opens in a new tab)</span>
            </a>
          </div>
        </div>
      ) : (
        <div>
          <h1 class="font-display font-optical-auto text-[clamp(2rem,5vw,3rem)] font-semibold leading-[1.1] tracking-[-0.03em] mb-10">
            {title}
          </h1>

          <div class="prose">
            <slot />
          </div>
        </div>
      )}

    </article>
  </main>

  <footer class="flex flex-wrap justify-between items-center gap-2 py-8 px-10 text-[0.8125rem] text-muted tracking-[0.03em] border-t border-subtle desk:px-16">
    <span>© {new Date().getFullYear()} radibit Ltd. All rights reserved.</span>
    <a href="mailto:contact@radibit.com" class="text-muted no-underline hover:underline">contact@radibit.com</a>
  </footer>
</Layout>
